<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <Description>Provides APIs for authenticating to Microsoft Entra ID</Description>
    <AssemblyTitle>Microsoft Azure.Identity Component</AssemblyTitle>
    <Version>1.22.0-beta.1</Version>
    <!--The ApiCompatVersion is managed automatically and should not generally be modified manually.-->
    <ApiCompatVersion>1.21.0</ApiCompatVersion>
    <PackageTags>Microsoft Azure Identity;$(PackageCommonTags)</PackageTags>
    <TargetFrameworks>$(RequiredTargetFrameworks)</TargetFrameworks>
    <NoWarn>$(NoWarn);3021;AZC0011</NoWarn>
    <GenAPIAdditionalParameters>--follow-type-forwards $(GenAPIAdditionalParameters)</GenAPIAdditionalParameters>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\..\core\Azure.Core\src\Azure.Core.csproj" />
  </ItemGroup>
</Project>
