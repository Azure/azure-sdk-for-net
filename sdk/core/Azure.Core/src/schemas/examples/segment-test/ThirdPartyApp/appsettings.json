{
    "AzureClients": {
        "BlobServiceClient": {
            "ServiceUri": "https://myaccount.blob.core.windows.net",
            "Credential": {
                "CredentialSource": "ChainedTokenCredential",
                "Sources": [
                    {
                        "CredentialSource": "AzureCliCredential"
                    }
                ]
            },
            "Options": {
                "Diagnostics": {
                    "IsLoggingEnabled": true,
                    "ApplicationId": "a"
                }
            }
        },
        "ArmClient": {
            "Credential": {
                "CredentialSource": "ApiKeyCredential"
            },
            "DefaultSubscriptionId": "a",
            "Options": {
                "AuxiliaryTenantIds": [
                    "tenant1",
                    "tenant2"
                ]
            }
        }
    },
    "Clients": {
        "MyClient": {
            "Credential": {
                "CredentialSource": "ApiKeyCredential"
            },
            "Options": {
                "EnableDistributedTracing": false
            }
        }
    }
}
