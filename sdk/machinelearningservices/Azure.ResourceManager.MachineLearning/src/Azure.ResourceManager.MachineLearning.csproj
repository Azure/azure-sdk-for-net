<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <Version>1.3.0-beta.1</Version>
    <!--The ApiCompatVersion is managed automatically and should not generally be modified manually.-->
    <ApiCompatVersion>1.2.3</ApiCompatVersion>
    <Description>Microsoft Azure management client SDK for Azure resource provider Microsoft.MachineLearningServices.</Description>
    <PackageId>Azure.ResourceManager.MachineLearning</PackageId>
    <PackageTags>azure;management;machinelearning;machinelearningservices;aml;ml</PackageTags>
    <DisableEnhancedAnalysis>true</DisableEnhancedAnalysis>
  </PropertyGroup>

  <PropertyGroup>
    <!-- Link to preapproved, registered namespaces: https://azure.github.io/azure-sdk/registered_namespaces.html  -->
    <!-- CS0109: 'new' keyword in serialization workaround for generator bug -->
    <NoWarn>$(NoWarn);CS1591;CS0109</NoWarn>
  </PropertyGroup>

  <!-- Generator bug: WorkspaceConnectionPropertiesV2BasicResourceData inherits ArmResource
       instead of ResourceData, so the generated 'override void JsonModelWriteCore' fails.
       A fixed copy with 'new' is in Customized/. -->
  <ItemGroup>
    <Compile Remove="Generated/WorkspaceConnectionPropertiesV2BasicResourceData.Serialization.cs" />
  </ItemGroup>
</Project>
