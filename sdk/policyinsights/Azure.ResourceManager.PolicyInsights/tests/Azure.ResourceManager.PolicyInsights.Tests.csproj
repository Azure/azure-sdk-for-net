<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <!--
      Auto-generated sample files reference obsolete GA-compat overloads (Options classes +
      extension methods) that are intentionally marked [Obsolete] in our customization.
      Samples are [Ignore]-d at runtime (only compilation-checked), so suppressing CS0618 for
      the test project avoids spurious build breaks whenever the obsolete surface changes.
    -->
    <NoWarn>$(NoWarn);CS0618</NoWarn>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="..\src\Azure.ResourceManager.PolicyInsights.csproj" />
  </ItemGroup>
  <ItemGroup>
    <Compile Include="$(TestFrameworkSupportFiles)" LinkBase="Shared\TestFramework" />
    <Compile Include="..\..\..\..\common\ManagementTestShared\Temp\*.cs" LinkBase="TestShared" />
  </ItemGroup>
</Project>
