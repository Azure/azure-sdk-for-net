<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <Version>1.3.0-beta.1</Version>
    <!--The ApiCompatVersion is managed automatically and should not generally be modified manually.-->
    <ApiCompatVersion>1.2.1</ApiCompatVersion>
    <PackageId>Azure.ResourceManager.Hci</PackageId>
    <Description>Microsoft Azure Resource Manager client SDK for Azure resource provider Microsoft.AzureStackHCI.</Description>
    <PackageTags>azure;management;arm;resource manager;azurestackhci</PackageTags>
    <NoWarn>$(NoWarn);AZC0032;AZC0030;CS0108</NoWarn>
  </PropertyGroup>
  <ItemGroup>
    <!-- Exclude generated internal ExtensionProfile; replaced by public version in Custom/ folder.
         The generator treats this read-only model as internal (usage analysis overrides @@access),
         but the model factory exposes it in a public method, causing CS0051. -->
    <Compile Remove="Generated\Models\ExtensionProfile.cs" />
    <Compile Remove="Generated\Models\ExtensionProfile.Serialization.cs" />
  </ItemGroup>
</Project>
