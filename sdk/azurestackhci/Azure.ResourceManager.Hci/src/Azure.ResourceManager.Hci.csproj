<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <Version>1.3.0-beta.1</Version>
    <!--The ApiCompatVersion is managed automatically and should not generally be modified manually.-->
    <ApiCompatVersion>1.2.1</ApiCompatVersion>
    <PackageId>Azure.ResourceManager.Hci</PackageId>
    <Description>Microsoft Azure Resource Manager client SDK for Azure resource provider Microsoft.AzureStackHCI.</Description>
    <PackageTags>azure;management;arm;resource manager;azurestackhci</PackageTags>
    <!-- AZC0032/AZC0030: Generated names retain spec naming that triggers Azure SDK analyzers (e.g. Data/Request suffixes);
         renamed via @@clientName where possible but some analyzer triggers remain.
         CS0108: Generated HciClusterUpdateRunData.Name hides inherited ResourceData.Name (tunnels to Properties.Name).
         CS0618: Backward-compat custom code intentionally references [Obsolete] types/members it wraps. -->
    <NoWarn>$(NoWarn);AZC0032;AZC0030;CS0108;CS0618</NoWarn>
  </PropertyGroup>
  <ItemGroup>
    <!-- Exclude generated ExtensionProfile; replaced by custom version in Custom/ folder.
         The generator's usage analysis overrides the @@access(Access.public) decorator on read-only models,
         producing incomplete code. The model factory exposes ExtensionProfile in a public method, causing CS0051.
         Tracked in https://github.com/Azure/azure-sdk-for-net/issues/56961 — remove when fixed. -->
    <Compile Remove="Generated\Models\ExtensionProfile.cs" />
    <Compile Remove="Generated\Models\ExtensionProfile.Serialization.cs" />
    <!-- TODO: Remove when generator correctly maps @@clientName for ExtensionInstanceView → ArcExtensionInstanceView
         in PerNodeExtensionState serialization (currently emits HciExtensionInstanceView.DeserializeHciExtensionInstanceView) -->
    <Compile Remove="Generated\Models\PerNodeExtensionState.Serialization.cs" />
  </ItemGroup>
</Project>
