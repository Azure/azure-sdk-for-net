<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFrameworks>$(RequiredTargetFrameworks)</TargetFrameworks>
    <!--Ensure all dependencies are copied to the output directory so that they can be packaged up for npm.-->
    <CopyLocalLockFileAssemblies>true</CopyLocalLockFileAssemblies>
    <NoWarn>$(NoWarn);IDT002</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.TypeSpec.Generator.ClientModel" />
  </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Include="stable-types_Azure.AI.Extensions.OpenAI.yaml" LogicalName="stable-types_Azure.AI.Extensions.OpenAI.yaml" />
    <EmbeddedResource Include="stable-types_Azure.AI.Projects.Agents.yaml" LogicalName="stable-types_Azure.AI.Projects.Agents.yaml" />
    <EmbeddedResource Include="stable-types_Azure.AI.Projects.yaml" LogicalName="stable-types_Azure.AI.Projects.yaml" />
  </ItemGroup>

  <!-- Copy output to package dist path for npm package consumption -->
  <Target Name="CopyForNpmPackage" AfterTargets="Build">
    <Message Text="Copying Extensions.Plugin output to dist path" Importance="high" />
    <ItemGroup>
      <SourceDir Include="$(OutputPath)**\*.*" />
    </ItemGroup>
    <Copy SourceFiles="@(SourceDir)" DestinationFolder="$(MSBuildThisFileDirectory)..\..\dist\%(RecursiveDir)" />
  </Target>
</Project>
