<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <Description>This is the Azure.AI.Projects.Agents client library for developing .NET applications with rich experience.</Description>
    <AssemblyTitle>SDK Code Generation Azure.AI.Projects.Agents</AssemblyTitle>
    <Version>2.0.0-beta.1</Version>
    <PackageTags>Azure.AI.Projects.Agents</PackageTags>
    <TargetFrameworks>$(RequiredTargetFrameworks)</TargetFrameworks>
    <LangVersion>latest</LangVersion>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <IncludeOperationsSharedSource>true</IncludeOperationsSharedSource>
  </PropertyGroup>

  <PropertyGroup>
    <!-- Acknowledge experimental OpenAI features -->
    <NoWarn>$(NoWarn);OPENAI001</NoWarn>
    <!-- Temporary suppression of XML doc requirement -->
    <NoWarn>$(NoWarn);CS1591</NoWarn>
    <!-- Ignore ModelFactory error (applied to externally originating types) -->
    <NoWarn>$(NoWarn);AZC0035</NoWarn>
    <!-- Ignore warnings about the experimental features -->
    <NoWarn>$(NoWarn);AAIP001</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="OpenAI"/>
    <PackageReference Include="Azure.Core" />
  </ItemGroup>

  <!-->ItemGroup>
    <Compile Include="$(AzureCoreSharedSources).cs" LinkBase="Shared" />
  </ItemGroup-->
</Project>
