<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <Version>1.4.0-beta.1</Version>
    <!--The ApiCompatVersion is managed automatically and should not generally be modified manually.-->
    <ApiCompatVersion>1.3.0</ApiCompatVersion>
    <PackageId>Azure.ResourceManager.ContainerInstance</PackageId>
    <Description>Microsoft Azure Resource Manager client SDK for Azure resource provider Microsoft.ContainerInstance.</Description>
    <PackageTags>azure;management;arm;resource manager;containerinstance</PackageTags>
    <DisableEnhancedAnalysis>true</DisableEnhancedAnalysis>
    <!-- Generator bug: ContainerGroupProfileRevision types have unused fields (CS0169) -->
    <!-- Generator bug: XML doc comments reference non-existent methods like GetCGProfiles (CS1574) -->
    <!-- Workaround: custom serialization uses ModelReaderWriter.Read<T> for ManagedServiceIdentity (IL2026/IL3050) -->
    <NoWarn>$(NoWarn);CS0169;CS1574;IL2026;IL3050</NoWarn>
  </PropertyGroup>
  <ItemGroup>
    <!-- Generator bug: ModelFactory has incorrect type references -->
    <!-- Generator bug: ContainerGroupCollection is incomplete (missing constructors, CRUD methods) -->
    <Compile Remove="Generated\ContainerGroupCollection.cs" />
    <Compile Remove="Generated\ArmContainerInstanceModelFactory.cs" />
    <!-- Generator bug: calls internal ManagedServiceIdentity.DeserializeManagedServiceIdentity from Azure.ResourceManager -->
    <Compile Remove="Generated\ContainerGroupData.Serialization.cs" />
    <Compile Remove="Generated\NGroupData.Serialization.cs" />
  </ItemGroup>
</Project>
