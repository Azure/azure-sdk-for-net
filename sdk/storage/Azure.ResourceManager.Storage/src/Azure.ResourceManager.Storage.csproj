<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <Version>1.7.0-beta.1</Version>
    <PackageId>Azure.ResourceManager.Storage</PackageId>
    <Description>Microsoft Azure management client SDK for Azure resource provider Microsoft.Storage.</Description>
    <PackageTags>azure;management;storage</PackageTags>
    <AotCompatOptOut>true</AotCompatOptOut>
    <ApiCompatVersion>1.6.0</ApiCompatVersion>
    <NoWarn>$(NoWarn);CS1591</NoWarn>
  </PropertyGroup>
  <ItemGroup>
    <!-- Exclude generated files that are replaced by customizations in Customize/ -->
    <Compile Remove="Generated/Models/StoragePublicAccessType.cs" />
    <Compile Remove="Generated/Models/StorageTaskAssignmentReport.cs" />
    <Compile Remove="Generated/Models/StorageTaskAssignmentReport.Serialization.cs" />
    <!-- Replace generated files to change internal parameterless constructors to public (CannotSealType fix) -->
    <Compile Remove="Generated/DeletedAccountData.cs" />
    <Compile Remove="Generated/FileServiceUsageData.cs" />
    <Compile Remove="Generated/ImmutabilityPolicyData.Serialization.cs" />
    <Compile Remove="Generated/StoragePrivateEndpointConnectionData.cs" />
    <Compile Remove="Generated/Models/StorageAccountSkuConversionStatus.cs" />
    <Compile Remove="Generated/Models/StorageTaskReportInstance.cs" />
    <Compile Remove="Generated/Models/StoragePrivateLinkResourceData.cs" />
    <!-- Replace generated enum with backward-compatible readonly struct -->
    <Compile Remove="Generated/Models/StorageAccountProvisioningState.cs" />
    <Compile Remove="Generated/Models/StorageAccountProvisioningState.Serialization.cs" />
    <!-- Replace generated struct that conflicts with custom backward-compat version -->
    <Compile Remove="Generated/Models/StorageAccountNetworkRuleAction.cs" />
  </ItemGroup>
</Project>
