<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <Version>1.2.0-beta.6</Version>
    <!--The ApiCompatVersion is managed automatically and should not generally be modified manually.-->
    <!--ApiCompatVersion temporarily removed during TypeSpec migration - backward compat overloads have type mismatches-->
    <PackageId>Azure.ResourceManager.HDInsight</PackageId>
    <Description>Microsoft Azure Resource Manager client SDK for Azure resource provider Microsoft.HDInsight.</Description>
    <PackageTags>azure;management;arm;resource manager;hdinsight</PackageTags>
    <DisableEnhancedAnalysis>true</DisableEnhancedAnalysis>
    <!-- Suppress XML doc cref errors and AOT warnings from generated code for primitive body serialization -->
    <NoWarn>$(NoWarn);CS1574;CS1580;IL2026;IL3050</NoWarn>
  </PropertyGroup>
</Project>
