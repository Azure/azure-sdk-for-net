<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFrameworks>$(RequiredTargetFrameworks)</TargetFrameworks>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="NUnit" />
    <PackageReference Include="NUnit3TestAdapter" />
    <PackageReference Include="Microsoft.NET.Test.Sdk" />
    <PackageReference Include="Moq" />
  </ItemGroup>

  <ItemGroup>
    <Compile Include="$(AzureCoreSharedSources)AzureResourceProviderNamespaceAttribute.cs"
             Link="Shared\Core\AzureResourceProviderNamespaceAttribute.cs" />
    <!--
      Link the analyzer-authoring skill's pure-C# validator so we can unit-test
      it without depending on cu-skill.csproj (which opts out of central package
      management and references the built SDK DLL via HintPath). The source is
      intentionally pure System.Text.Json with no Azure.* imports — see the
      SkillSchemaValidatorTests purity guard.
    -->
    <Compile Include="..\.github\skills\_shared\SchemaValidator.cs"
             Link="Skills\_shared\SchemaValidator.cs" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="$(AzureCoreTestFramework)" />
    <ProjectReference Include="..\src\Azure.AI.ContentUnderstanding.csproj" />
  </ItemGroup>

  <ItemGroup>
    <None Update="samples\SampleFiles\**\*">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>

</Project>
