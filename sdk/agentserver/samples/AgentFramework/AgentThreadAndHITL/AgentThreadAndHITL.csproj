<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net8.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
  </PropertyGroup>

  <PropertyGroup>
    <NoWarn>$(NoWarn);MEAI001</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Agents.AI.OpenAI" Version="1.0.0-rc1" />
  </ItemGroup>

  <ItemGroup Condition="'$(UseProjectReference)'=='true'">
    <ProjectReference Include="..\..\..\Azure.AI.AgentServer.AgentFramework\src\Azure.AI.AgentServer.AgentFramework.csproj" />
  </ItemGroup>

  <ItemGroup Condition="'$(UseProjectReference)'!='true'">
    <PackageReference Include="Azure.AI.AgentServer.AgentFramework" />
  </ItemGroup>

</Project>
