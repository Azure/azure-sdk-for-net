<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFrameworks>$(RequiredRunnableTargetFrameworks)</TargetFrameworks>
    <RootNamespace>Azure.AI.AgentServer.Responses</RootNamespace>
    <Version>1.0.0-beta.1</Version>
    <Description>An SDK for building ASP.NET Core servers that implement the Azure AI Responses API.</Description>
    <PackageTags>Azure.AI.AgentServer.Responses</PackageTags>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <Nullable>enable</Nullable>
  </PropertyGroup>

  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\Azure.AI.AgentServer.Responses.Contracts\src\Azure.AI.AgentServer.Responses.Contracts.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Azure.Identity" />
  </ItemGroup>

</Project>
