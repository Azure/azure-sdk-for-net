<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <Version>1.12.0-beta.1</Version>
    <!--The ApiCompatVersion is managed automatically and should not generally be modified manually.-->
    <ApiCompatVersion>1.11.0</ApiCompatVersion>
    <PackageId>Azure.ResourceManager.DataFactory</PackageId>
    <Description>Microsoft Azure Resource Manager client SDK for Azure resource provider Microsoft.DataFactory.</Description>
    <PackageTags>azure;management;arm;resource manager;datafactory</PackageTags>
    <DisableEnhancedAnalysis>true</DisableEnhancedAnalysis>
    <AotCompatOptOut>true</AotCompatOptOut>
  </PropertyGroup>

  <!--
    The MPG generator currently emits a handful of known-broken patterns (Deserialize* calls
    against SDK-provided types, IDictionary<,>.ToRequestContent, additionalProperties /
    additionalBinaryDataProperties variable-name mismatch, ETag/string parameter aliasing,
    Unknown* discriminator naming and a few ApiCompat shape regressions). Until those are fixed
    upstream, post-gen-fixups.ps1 mechanically patches the generated tree. Running it as an
    AfterTargets hook keeps local builds and CI (`/t:GenerateCode` on service.proj) in sync.
  -->
  <Target Name="ApplyPostGenFixups" AfterTargets="GenerateCode" Condition="'$(TypeSpecInput)' != ''">
    <Exec Command="pwsh -NoProfile -ExecutionPolicy Bypass -File &quot;$(MSBuildThisFileDirectory)post-gen-fixups.ps1&quot; -PackageRoot &quot;$(MSBuildThisFileDirectory)..&quot;" />
  </Target>
</Project>
