<Project Sdk="Microsoft.NET.Sdk">

  <!--
    Code-fix providers split off from Azure.SdkAnalyzers so that assembly stays
    free of Microsoft.CodeAnalysis.Workspaces (a CodeFix dependency). Workspaces
    isn't provided by csc at command-line build time, and any analyzer assembly
    that references it has its DiagnosticAnalyzer / DiagnosticSuppressor types
    silently skipped by Roslyn's loader (see RS1038). Internal-use only — not
    packaged.
  -->
  <PropertyGroup>
    <GenerateDocumentationFile>false</GenerateDocumentationFile>
    <EnableClientSdkAnalyzers>false</EnableClientSdkAnalyzers>
    <IsPackable>false</IsPackable>
    <IsShippingLibrary>false</IsShippingLibrary>
    <DevelopmentDependency>true</DevelopmentDependency>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.CodeAnalysis.CSharp" PrivateAssets="All" />
    <PackageReference Include="Microsoft.CodeAnalysis.CSharp.Workspaces" PrivateAssets="All" />
    <PackageReference Update="NETStandard.Library" PrivateAssets="All" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\Azure.SdkAnalyzers\src\Azure.SdkAnalyzers.csproj" PrivateAssets="All" />
  </ItemGroup>

</Project>
