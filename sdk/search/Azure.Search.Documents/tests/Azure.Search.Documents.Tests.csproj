<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFrameworks>$(RequiredTargetFrameworks)</TargetFrameworks>

    <!-- We don't care about XML doc comments on test methods -->
    <NoWarn>$(NoWarn);CS1591</NoWarn>
  </PropertyGroup>

  <!--Mirror the AZURE_SEARCH_PREVIEW constant from the src project so test code can
      conditionally compile preview-only test fixtures and ServiceVersion references.
      We read the version from the src .csproj because the test project has its own version.-->
  <Choose>
    <When Condition="$([System.Text.RegularExpressions.Regex]::IsMatch('$([System.IO.File]::ReadAllText($(MSBuildThisFileDirectory)..\src\Azure.Search.Documents.csproj))', '&lt;Version&gt;[^&lt;]*-beta'))">
      <PropertyGroup>
        <DefineConstants>$(DefineConstants);AZURE_SEARCH_PREVIEW</DefineConstants>
      </PropertyGroup>
    </When>
  </Choose>

  <ItemGroup Condition="'$(IsTargetingNetFx)' == 'true'">
    <Reference Include="System.ComponentModel.DataAnnotations" />
  </ItemGroup>

  <!-- Reference the Client Library -->
  <ItemGroup>
    <ProjectReference Include="..\src\Azure.Search.Documents.csproj" />
  </ItemGroup>

  <!-- Add Test References -->
  <ItemGroup Condition="'$(IsTestProject)' == 'true' and '$(IsClientLibrary)' == 'true'">
    <PackageReference Include="Microsoft.NET.Test.Sdk" />
    <PackageReference Include="NUnit" />
    <PackageReference Include="NUnit3TestAdapter" />
    <PackageReference Include="Moq" />
    <PackageReference Include="BenchmarkDotNet" />
    <ProjectReference Include="$(AzureCoreTestFramework)" />
  </ItemGroup>

 <!-- References required for sample snippet -->
  <ItemGroup>
    <PackageReference Include="Azure.AI.OpenAI" />
  </ItemGroup>

  <!-- References required for test resource creation -->
  <ItemGroup>
    <PackageReference Include="Azure.Storage.Blobs" />
    <PackageReference Include="Azure.Security.KeyVault.Keys" />
    <PackageReference Include="Microsoft.Spatial" />
  </ItemGroup>

  <ItemGroup>
    <Compile Update="Samples\Sample01_HelloWorld.Data.cs" DependentUpon="Sample01_HelloWorld.cs" />
  </ItemGroup>

  <!-- Pull in Shared Source from Azure.Core -->
  <ItemGroup>
    <Compile Include="$(AzureCoreSharedSources)HashCodeBuilder.cs" LinkBase="Shared" />
  </ItemGroup>

  <!-- Pull in Microsoft.Azure.Core.Spatial -->
  <Import Project="..\..\..\core\Microsoft.Azure.Core.Spatial\src\Microsoft.Azure.Core.Spatial.props" />
</Project>
