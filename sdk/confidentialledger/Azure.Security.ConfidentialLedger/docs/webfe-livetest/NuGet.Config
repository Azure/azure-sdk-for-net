<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!-- Scoped NuGet config: only nuget.org. Avoids picking up internal feeds from the repo root
       that may not be reachable on every dev machine. -->
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
</configuration>
