<Project>
  <!--
    NUnit 3 baseline pinning.

    The repository default is now NUnit 4.4.0 + NUnit3TestAdapter 4.6.0.
    Projects listed here are temporarily pinned to NUnit 3.14.0 until they
    are individually migrated.

    To migrate a project:
      1. Remove its name from the condition below.
      2. Fix any NUnit 4 breaking changes (assertion model, attributes, etc.).
      3. Verify tests pass.
  -->
  <ItemGroup Condition="('$(IsTestProject)' == 'true'
      or '$(IsTestSupportProject)' == 'true'
      or '$(IsPerfProject)' == 'true'
      or '$(IsStressProject)' == 'true'
      or '$(IsSamplesProject)' == 'true') and (
        $(MSBuildProjectName) == 'Azure.AI.Agents.Persistent.Tests' or
        $(MSBuildProjectName) == 'Azure.AI.AnomalyDetector.Tests' or
