<Project>
  <!--
    FluentAssertions is approved only for legacy use. Azure SDK test projects should
    use NUnit assertions.
  -->
  <ItemGroup Condition="'$(IsTestProject)' == 'true'">
    <PackageVersion Update="NUnit" Version="3.14.0" />
    <PackageVersion Update="NUnit3TestAdapter" Version="4.6.0" />
    <PackageVersion Include="FluentAssertions" Version="$(FluentAssertionsVersion)" />
  </ItemGroup>
</Project>
