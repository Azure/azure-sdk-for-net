<Project>
  <!--
    MSTest is approved only for use with Playwright. Azure SDK test projects should
    use NUnit.
  -->
  <ItemGroup>
    <PackageVersion Include="MSTest.TestFramework" Version="$(MSTestVersion)" />
  </ItemGroup>
  <ItemGroup Condition="'$(IsTestProject)' == 'true'">
    <PackageVersion Update="NUnit" Version="3.14.0" />
    <PackageVersion Update="NUnit3TestAdapter" Version="4.6.0" />
  </ItemGroup>
</Project>
