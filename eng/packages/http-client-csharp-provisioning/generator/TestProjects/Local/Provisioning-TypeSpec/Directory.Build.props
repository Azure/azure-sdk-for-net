<Project>
  <Import Project="$([MSBuild]::GetDirectoryNameOfFileAbove($(MSBuildThisFileDirectory).., Directory.Build.props))\Directory.Build.props" />

  <!-- Polyfill for ExperimentalAttribute on netstandard2.0.
       Real SDK projects get this from sdk/<service>/Azure.Provisioning.*/Directory.Build.props
       via $(AzureCoreSharedSources). The test project doesn't inherit from the SDK tree,
       so we include it directly. -->
  <ItemGroup>
    <Compile Include="$(MSBuildThisFileDirectory)..\..\..\..\..\..\..\sdk\core\Azure.Core\src\Shared\ExperimentalAttribute.cs" LinkBase="Shared" />
  </ItemGroup>
</Project>
