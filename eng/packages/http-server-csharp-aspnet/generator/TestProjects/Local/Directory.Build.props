<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup>
    <IsClientLibrary>true</IsClientLibrary>
    <IsTestProject>false</IsTestProject>
  </PropertyGroup>
  <!--
    Generated test projects are not first-party SDK libraries — they exist purely
    to validate end-to-end emitter+generator output. The flags above prevent the
    repo's SDK build infrastructure from treating them as shipping libraries.
  -->
  <Import Project="$([MSBuild]::GetDirectoryNameOfFileAbove($(MSBuildThisFileDirectory).., Directory.Build.props))\Directory.Build.props" />
  <ItemGroup>
    <!--
      Generated server code may reference System.BinaryData (the base TypeFactory's
      mapping for the TypeSpec `unknown` primitive). System.Memory.Data is the
      package that ships BinaryData. Real consumers of this generator will add the
      same dependency to their own server projects.
    -->
    <PackageReference Include="System.Memory.Data" />
  </ItemGroup>
</Project>
